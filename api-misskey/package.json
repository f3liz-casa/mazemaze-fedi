{
  "name": "@f3liz/mazemaze-api-misskey",
  "version": "0.11.0",
  "description": "Typed Misskey API client \u2014 one Melange runtime, with ReScript, TypeScript (JSDoc) and Melange surfaces. Generated by @f3liz/mazemaze-generator.",
  "keywords": [
    "misskey",
    "rescript",
    "bindings",
    "activitypub",
    "fediverse",
    "openapi"
  ],
  "author": "NyanRus",
  "license": "MIT",
  "type": "module",
  "main": "./src/Misskey.js",
  "module": "./src/Misskey.res.mjs",
  "types": "./src/Misskey.d.ts",
  "exports": {
    ".": {
      "import": "./src/Misskey.res.mjs",
      "require": "./src/Misskey.js",
      "types": "./src/Misskey.d.ts"
    },
    "./endpoints": "./src/melange-api/Endpoints.res.mjs",
    "./components": "./src/melange-api/ComponentSchemas.res.mjs",
    "./melange-endpoints": "./src/melange-api/melange-dist/Endpoints.js",
    "./melange-components": "./src/melange-api/melange-dist/ComponentSchemas.js",
    "./src/*": "./src/*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/f3liz-casa/rescript-misskey-api.git"
  },
  "scripts": {
    "build": "npm run build:melange && rescript",
    "build:melange": "bash scripts/build-melange.sh",
    "build:rescript": "rescript",
    "clean": "rescript clean",
    "watch": "rescript build -w",
    "generate": "bash scripts/generate-melange.sh",
    "test": "rescript",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ofetch": "^1.5.1"
  },
  "devDependencies": {
    "@f3liz/mazemaze-generator": "*",
    "acorn": "^8.17.0",
    "rescript": "^12.1.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "src/**/*.res",
    "src/**/*.resi",
    "src/**/*.res.mjs",
    "src/**/*.d.ts",
    "src/**/*.mjs",
    "src/Misskey.js",
    "src/melange-api/melange-dist/**/*.js",
    "src/melange-api/melange-dist/**/package.json",
    "melange/*.ml",
    "melange/dune",
    "melange/dune-project",
    "scripts/build-melange.sh",
    "rescript.json",
    "README.md",
    "LICENSE"
  ]
}