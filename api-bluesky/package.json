{
  "name": "@f3liz/mazemaze-api-bluesky",
  "version": "0.1.0",
  "description": "Typed Bluesky (atproto app.bsky) API client \u2014 one Melange runtime, with ReScript, TypeScript (JSDoc) and Melange surfaces. Generated by @f3liz/mazemaze-generator.",
  "type": "module",
  "scripts": {
    "generate": "bash scripts/generate-melange.sh",
    "build:melange": "bash scripts/build-melange.sh",
    "build": "npm run build:melange && rescript",
    "clean": "rescript clean",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    "./endpoints": "./src/melange-api/Endpoints.res.mjs",
    "./components": "./src/melange-api/ComponentSchemas.res.mjs",
    "./melange-endpoints": "./src/melange-api/melange-dist/Endpoints.js",
    "./melange-components": "./src/melange-api/melange-dist/ComponentSchemas.js"
  },
  "files": [
    "src/melange-api/*.res",
    "src/melange-api/*.res.mjs",
    "src/melange-api/melange-dist/**/*.js",
    "src/melange-api/melange-dist/**/package.json",
    "melange/*.ml",
    "melange/dune",
    "melange/dune-project",
    "scripts/build-melange.sh",
    "rescript.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "bluesky",
    "atproto",
    "atprotocol",
    "fediverse",
    "openapi",
    "melange",
    "rescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@f3liz/mazemaze-generator": "*",
    "acorn": "^8.17.0",
    "rescript": "^12.1.0"
  }
}