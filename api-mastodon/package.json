{
  "name": "@f3liz/mazemaze-api-mastodon",
  "version": "0.11.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Typed Mastodon API client — one Melange runtime, with ReScript, TypeScript (JSDoc) and Melange surfaces. Generated by @f3liz/mazemaze-generator.",
  "type": "module",
  "main": "./src/Mastodon.js",
  "types": "./src/Mastodon.d.ts",
  "scripts": {
    "generate": "bash scripts/generate-melange.sh",
    "build:melange": "bash scripts/build-melange.sh",
    "build:rescript": "rescript",
    "build:write-types": "node scripts/write-types.mjs",
    "build:ts": "tsc",
    "build": "npm run build:melange && npm run build:rescript && npm run build:write-types && npm run build:ts",
    "clean": "rescript clean",
    "prepublishOnly": "npm run build"
  },
  "exports": {
