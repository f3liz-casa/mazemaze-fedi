      "import": "./src/Mastodon.js",
      "types": "./src/Mastodon.d.ts"
    },
    "./endpoints": "./src/melange-api/Endpoints.res.mjs",
    "./components": "./src/melange-api/ComponentSchemas.res.mjs",
    "./melange-endpoints": "./src/melange-api/melange-dist/Endpoints.js",
    "./melange-components": "./src/melange-api/melange-dist/ComponentSchemas.js"
  },
  "files": [
    "src/Mastodon.ts",
    "src/Mastodon.js",
    "src/Mastodon.d.ts",
    "src/melange-api/*.res",
    "src/melange-api/*.res.mjs",
    "src/melange-api/melange-dist/**/*.js",
    "src/melange-api/melange-dist/**/*.d.ts",
    "src/melange-api/melange-dist/**/package.json",
    "melange/*.ml",
    "melange/dune",
    "melange/dune-project",
    "src/melange-api-types/Endpoints.d.ts",
    "scripts/build-melange.sh",
    "scripts/write-types.mjs",
    "tsconfig.json",
    "rescript.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mastodon",
    "activitypub",
    "fediverse",
    "openapi",
    "melange",
    "rescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@f3liz/mazemaze-generator": "*",
    "acorn": "^8.17.0",
    "rescript": "^12.1.0",
    "typescript": "^5.9.3"
  }
